{
  "name": "@xylabs/sdk-react-build",
  "version": "7.1.17",
  "private": true,
  "description": "Common React library for all XY Labs projects that use React",
  "keywords": [
    "utility",
    "typescript",
    "react"
  ],
  "homepage": "https://xylabs.com",
  "bugs": {
    "url": "git+https://github.com/xylabs/sdk-react/issues",
    "email": "support@xylabs.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xylabs/sdk-react.git"
  },
  "license": "LGPL-3.0-only",
  "author": {
    "name": "XY Labs Development Team",
    "email": "support@xylabs.com",
    "url": "https://xylabs.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/browser/index.d.ts",
      "default": "./dist/browser/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/browser/index.mjs",
  "types": "dist/browser/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build-storybook": "storybook build",
    "build-typedoc-site": "typedoc && storybook build -o ./docs/storybook",
    "knip:unlisted": "echo ---Unlisted Dependencies--- && yarn workspaces foreach -Ap --exclude @xyo-network/sdk-js --no-interlaced run knip --include unlisted",
    "publish-all": "npm publish --workspaces",
    "start": "NODE_OPTIONS=--max_old_space_size=8192 storybook dev -p 6006",
    "storybook": "storybook dev -p 6006"
  },
  "browserslist": {
    "production": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@emotion/react": "~11.14.0",
    "@emotion/styled": "~11.14.1",
    "@mui/icons-material": "~7.3.9",
    "@mui/material": "~7.3.9",
    "@storybook/addon-links": "~10.2.16",
    "@storybook/react-vite": "~10.2.16",
    "@stylistic/eslint-plugin": "~5.10.0",
    "@types/node": "~25.3.5",
    "@types/react": "^19.2.14",
    "@xylabs/eslint-config-flat": "~7.4.9",
    "@xylabs/eslint-config-react-flat": "~7.4.9",
    "@xylabs/react-crypto": "~7.1.17",
    "@xylabs/ts-scripts-yarn3": "~7.4.9",
    "@xylabs/tsconfig": "~7.4.9",
    "@xylabs/tsconfig-dom": "~7.4.9",
    "@xylabs/tsconfig-react": "~7.4.9",
    "eslint": "~9.39.4",
    "eslint-import-resolver-typescript": "~4.4.4",
    "eslint-plugin-jsdoc": "~62.7.1",
    "eslint-plugin-react-hooks": "~7.0.1",
    "eslint-plugin-storybook": "~10.2.16",
    "knip": "~5.86.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "~10.2.16",
    "ts-api-utils": "~2.4.0",
    "typedoc": "~0.28.17",
    "typescript": "^5.9.3",
    "vite": "~7.3.1",
    "zod": "~4.3.6"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=6 <8",
    "@mui/material": ">=6 <8",
    "axios": "^1",
    "react": "^19",
    "react-dom": "^19",
    "react-helmet": "^7",
    "react-router-dom": "^7",
    "zod": "^4"
  },
  "packageManager": "yarn@4.13.0",
  "volta": {
    "node": "22.15.0",
    "yarn": "4.9.1"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
